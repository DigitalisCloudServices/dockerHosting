# ── sysctl application ────────────────────────────────────────────────────────

@test "harden-kernel: invokes sysctl to apply settings" {
    local test_script="$BATS_TEST_TMPDIR/harden-kernel-test.sh"
    sed "s|/etc/sysctl.d|$SYSCTL_DIR|g" "$SCRIPTS_DIR/harden-kernel.sh" > "$test_script"
    chmod +x "$test_script"
    
    bash "$test_script"
    
    # Verify sysctl was called with -p flag
    [ -f "$SYSCTL_LOG" ]
    grep -q "\-p" "$SYSCTL_LOG"
}

@test "harden-kernel: sysctl applies the generated config file" {
    local test_script="$BATS_TEST_TMPDIR/harden-kernel-test.sh"
    sed "s|/etc/sysctl.d|$SYSCTL_DIR|g" "$SCRIPTS_DIR/harden-kernel.sh" > "$test_script"
    chmod +x "$test_script"
    
    bash "$test_script"
    
    grep -q "99-security.conf" "$SYSCTL_LOG"
}

