#!/usr/bin/env bats
# Tests for scripts/harden-usb.sh
# Validates USB/removable media device restrictions via kernel module blacklisting

load '../helpers/common'

setup() {
    setup_mocks
    
    # Override modprobe.d directory to test location
    export MODPROBE_DIR="$BATS_TEST_TMPDIR/etc/modprobe.d"
    mkdir -p "$MODPROBE_DIR"
    
    # Mock lsmod to simulate loaded/unloaded module states
    LSMOD_LOG="$BATS_TEST_TMPDIR/lsmod.log"
    create_mock_with_body "lsmod" "
        if [[ -f \"$BATS_TEST_TMPDIR/modules_loaded\" ]]; then
            cat <<'LSMOD_EOF'
Module                  Size  Used by
usb_storage            73728  0
firewire_core         81920  1 firewire_ohci
LSMOD_EOF
        else
            cat <<'LSMOD_EOF'
Module                  Size  Used by
ext4                  786432  1
LSMOD_EOF
        fi
        exit 0
    "
    
    # Mock update-initramfs command
    INITRAMFS_LOG="$BATS_TEST_TMPDIR/initramfs.log"
    create_call_log_mock "update-initramfs" "$INITRAMFS_LOG"
    
    # Mock command to control availability of update-initramfs
    create_mock_with_body "command" "
        if [[ \"\$1\" == \"-v\" && \"\$2\" == \"update-initramfs\" ]]; then
            if [[ -f \"$BATS_TEST_TMPDIR/has_initramfs\" ]]; then
                exit 0
            else
                exit 1
            fi
        fi
        /usr/bin/command \"\$@\"
    "
    
    # Patch the script to use our overridden paths
    HARDEN_USB_SCRIPT="$BATS_TEST_TMPDIR/harden-usb-patched.sh"
    sed \
        -e "s|/etc/modprobe.d|$MODPROBE_DIR|g" \
        "$SCRIPTS_DIR/harden-usb.sh" > "$HARDEN_USB_SCRIPT"
    chmod +x "$HARDEN_USB_SCRIPT"
}

teardown() {
    teardown_mocks
}

# ── modprobe.d file generation ────────────────────────────────────────────────

@test "harden-usb: creates harden-usb.conf in modprobe.d" {
    run bash "$HARDEN_USB_SCRIPT"
    [ "$status" -eq 0 ]
    assert_file_exists "$MODPROBE_DIR/harden-usb.conf"
}

@test "harden-usb: config file has correct header" {
    bash "$HARDEN_USB_SCRIPT"
    assert_file_contains "$MODPROBE_DIR/harden-usb.conf" "# USB/removable media kernel module blacklist"
    assert_file_contains "$MODPROBE_DIR/harden-usb.conf" "# Generated by harden-usb.sh"
}

@test "harden-usb: config file references compliance frameworks" {
    bash "$HARDEN_USB_SCRIPT"
    assert_file_contains "$MODPROBE_DIR/harden-usb.conf" "# CIS Benchmark L2 1.1.x"
    assert_file_contains "$MODPROBE_DIR/harden-usb.conf" "UK Cyber Essentials Plus"
}

@test "harden-usb: config file is valid conf syntax (no HEREDOC markers)" {
    bash "$HARDEN_USB_SCRIPT"
    refute_file_contains "$MODPROBE_DIR/harden-usb.conf" "EOF"
    refute_file_contains "$MODPROBE_DIR/harden-usb.conf" "<<'"
}

# ── USB storage blacklist directives ──────────────────────────────────────────

@test "harden-usb: blacklists usb-storage module" {
    bash "$HARDEN_USB_SCRIPT"
    assert_file_contains "$MODPROBE_DIR/harden-usb.conf" "blacklist usb-storage"
}

@test "harden-usb: sets usb-storage install to /bin/false" {
    bash "$HARDEN_USB_SCRIPT"
    assert_file_contains "$MODPROBE_DIR/harden-usb.conf" "install usb-storage /bin/false"
}

@test "harden-usb: usb-storage section has descriptive comment" {
    bash "$HARDEN_USB_SCRIPT"
    assert_file_contains "$MODPROBE_DIR/harden-usb.conf" "# USB storage devices"
}

