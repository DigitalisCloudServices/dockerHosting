# ── idempotency ───────────────────────────────────────────────────────────────

@test "harden-kernel: skips configuration when 99-security.conf already exists" {
    local test_script="$BATS_TEST_TMPDIR/harden-kernel-test.sh"
    sed "s|/etc/sysctl.d|$SYSCTL_DIR|g" "$SCRIPTS_DIR/harden-kernel.sh" > "$test_script"
    chmod +x "$test_script"
    
    # First run
    bash "$test_script"
    
    # Mark the config file with a unique identifier
    echo "# ORIGINAL RUN" >> "$SYSCTL_DIR/99-security.conf"
    
    # Second run should skip
    run bash "$test_script"
    [ "$status" -eq 0 ]
    [[ "$output" == *"already hardened"* ]]
    [[ "$output" == *"skipping"* ]]
    
    # Unique identifier should still be present (file not overwritten)
    assert_file_contains "$SYSCTL_DIR/99-security.conf" "# ORIGINAL RUN"
}

@test "harden-kernel: idempotent skip message mentions --force flag" {
    local test_script="$BATS_TEST_TMPDIR/harden-kernel-test.sh"
    sed "s|/etc/sysctl.d|$SYSCTL_DIR|g" "$SCRIPTS_DIR/harden-kernel.sh" > "$test_script"
    chmod +x "$test_script"
    
    bash "$test_script"
    
    run bash "$test_script"
    [ "$status" -eq 0 ]
    [[ "$output" == *"--force"* ]]
}

# ── --force flag ──────────────────────────────────────────────────────────────

@test "harden-kernel: --force flag reconfigures even when config exists" {
    local test_script="$BATS_TEST_TMPDIR/harden-kernel-test.sh"
    sed "s|/etc/sysctl.d|$SYSCTL_DIR|g" "$SCRIPTS_DIR/harden-kernel.sh" > "$test_script"
    chmod +x "$test_script"
    
    # First run
    bash "$test_script"
    
    # Mark the config file
    echo "# FIRST RUN" >> "$SYSCTL_DIR/99-security.conf"
    
    # Force reconfiguration
    run bash "$test_script" --force
    [ "$status" -eq 0 ]
    [[ "$output" != *"already hardened"* ]]
    
    # Original marker should be gone (file overwritten)
    refute_file_contains "$SYSCTL_DIR/99-security.conf" "# FIRST RUN"
}

@test "harden-kernel: --force flag can appear anywhere in arguments" {
    local test_script="$BATS_TEST_TMPDIR/harden-kernel-test.sh"
    sed "s|/etc/sysctl.d|$SYSCTL_DIR|g" "$SCRIPTS_DIR/harden-kernel.sh" > "$test_script"
    chmod +x "$test_script"
    
    bash "$test_script"
    echo "# MARKER" >> "$SYSCTL_DIR/99-security.conf"
    
    # Force with trailing position
    run bash "$test_script" --force
    [ "$status" -eq 0 ]
    refute_file_contains "$SYSCTL_DIR/99-security.conf" "# MARKER"
}

