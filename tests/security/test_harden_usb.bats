# ── Thunderbolt blacklist directives ──────────────────────────────────────────

@test "harden-usb: blacklists thunderbolt module" {
    bash "$HARDEN_USB_SCRIPT"
    assert_file_contains "$MODPROBE_DIR/harden-usb.conf" "blacklist thunderbolt"
}

@test "harden-usb: sets thunderbolt install to /bin/false" {
    bash "$HARDEN_USB_SCRIPT"
    assert_file_contains "$MODPROBE_DIR/harden-usb.conf" "install thunderbolt /bin/false"
}

@test "harden-usb: thunderbolt section mentions DMA bypass risk" {
    bash "$HARDEN_USB_SCRIPT"
    assert_file_contains "$MODPROBE_DIR/harden-usb.conf" "# Thunderbolt"
}

# ── initramfs update ──────────────────────────────────────────────────────────

@test "harden-usb: rebuilds initramfs when update-initramfs is available" {
    touch "$BATS_TEST_TMPDIR/has_initramfs"
    bash "$HARDEN_USB_SCRIPT"
    assert_file_exists "$INITRAMFS_LOG"
    assert_file_contains "$INITRAMFS_LOG" "-u"
}

@test "harden-usb: skips initramfs rebuild when update-initramfs is unavailable" {
    # Don't create has_initramfs marker
    run bash "$HARDEN_USB_SCRIPT"
    [ "$status" -eq 0 ]
    if [[ -f "$INITRAMFS_LOG" ]]; then
        run cat "$INITRAMFS_LOG"
        [ "$status" -eq 0 ]
        [ -z "$output" ]
    fi
}

# ── loaded module detection ───────────────────────────────────────────────────

@test "harden-usb: warns when blacklisted modules are currently loaded" {
    touch "$BATS_TEST_TMPDIR/modules_loaded"
    run bash "$HARDEN_USB_SCRIPT"
    [ "$status" -eq 0 ]
    [[ "$output" =~ "modules are currently loaded" ]]
    [[ "$output" =~ "Reboot required" ]]
}

@test "harden-usb: reports clean state when no blacklisted modules are loaded" {
    # Don't create modules_loaded marker
    run bash "$HARDEN_USB_SCRIPT"
    [ "$status" -eq 0 ]
    [[ "$output" =~ "No affected modules are currently loaded" ]]
}

# ── idempotency ───────────────────────────────────────────────────────────────

@test "harden-usb: skips configuration when file exists (idempotent)" {
    # First run creates the file
    bash "$HARDEN_USB_SCRIPT"
    assert_file_exists "$MODPROBE_DIR/harden-usb.conf"
    
    # Second run should skip
    run bash "$HARDEN_USB_SCRIPT"
    [ "$status" -eq 0 ]
    [[ "$output" =~ "already configured" ]]
    [[ "$output" =~ "Use --force to overwrite" ]]
}

@test "harden-usb: overwrites configuration when --force is used" {
    # First run
    bash "$HARDEN_USB_SCRIPT"
    
    # Modify the file to detect overwrite
    echo "# MODIFIED" >> "$MODPROBE_DIR/harden-usb.conf"
    assert_file_contains "$MODPROBE_DIR/harden-usb.conf" "# MODIFIED"
    
    # Second run with --force should overwrite
    bash "$HARDEN_USB_SCRIPT" --force
    refute_file_contains "$MODPROBE_DIR/harden-usb.conf" "# MODIFIED"
    assert_file_contains "$MODPROBE_DIR/harden-usb.conf" "blacklist usb-storage"
}

@test "harden-usb: idempotent behaviour preserves original file on second run" {
    bash "$HARDEN_USB_SCRIPT"
    
    # Capture original content
    local original
    original="$(cat "$MODPROBE_DIR/harden-usb.conf")"
    
    # Second run
    bash "$HARDEN_USB_SCRIPT"
    
    # Content should be identical (file not rewritten)
    local current
    current="$(cat "$MODPROBE_DIR/harden-usb.conf")"
    [ "$original" = "$current" ]
}

# ── root privilege requirement ────────────────────────────────────────────────

@test "harden-usb: requires root privileges (EUID check)" {
    # Patch script to simulate non-root user
    local nonroot_script="$BATS_TEST_TMPDIR/harden-usb-nonroot.sh"
    sed \
        -e "s|/etc/modprobe.d|$MODPROBE_DIR|g" \
        -e 's/\$EUID/999/g' \
        "$SCRIPTS_DIR/harden-usb.sh" > "$nonroot_script"
    chmod +x "$nonroot_script"
    
    run bash "$nonroot_script"
    [ "$status" -eq 1 ]
    [[ "$output" =~ "must be run as root" ]]
}

# ── completion messages ───────────────────────────────────────────────────────

@test "harden-usb: displays completion message" {
    run bash "$HARDEN_USB_SCRIPT"
    [ "$status" -eq 0 ]
    [[ "$output" =~ "USB/removable media hardening complete" ]]
}

@test "harden-usb: clarifies USB keyboards/mice are unaffected" {
    run bash "$HARDEN_USB_SCRIPT"
    [ "$status" -eq 0 ]
    [[ "$output" =~ "USB keyboards, mice, and network adapters are unaffected" ]]
    [[ "$output" =~ "Only mass storage, FireWire, and Thunderbolt are blocked" ]]
}

@test "harden-usb: confirms config file location in output" {
    run bash "$HARDEN_USB_SCRIPT"
    [ "$status" -eq 0 ]
    [[ "$output" =~ "Written: $MODPROBE_DIR/harden-usb.conf" ]]
}
