---
# Traefik Dynamic Configuration for {{SITE_NAME}}
# Generated by dockerHosting
# Domain: {{DOMAIN}} → localhost:{{PORT}}

http:
  routers:
    {{SITE_NAME}}:
      rule: "Host(`{{DOMAIN}}`)"
      entryPoints:
        - websecure
      service: {{SITE_NAME}}
      tls: {}
      middlewares:
        - security-headers@file

  services:
    {{SITE_NAME}}:
      loadBalancer:
        passHostHeader: true
        servers:
          - url: "http://127.0.0.1:{{PORT}}"
