@test "harden-usb: blacklists firewire-core module" {
    bash "$HARDEN_USB_SCRIPT"
    assert_file_contains "$MODPROBE_DIR/harden-usb.conf" "blacklist firewire-core"
}

@test "harden-usb: sets firewire-core install to /bin/false" {
    bash "$HARDEN_USB_SCRIPT"
    assert_file_contains "$MODPROBE_DIR/harden-usb.conf" "install firewire-core /bin/false"
}

@test "harden-usb: blacklists firewire-ohci module" {
    bash "$HARDEN_USB_SCRIPT"
    assert_file_contains "$MODPROBE_DIR/harden-usb.conf" "blacklist firewire-ohci"
}

@test "harden-usb: sets firewire-ohci install to /bin/false" {
    bash "$HARDEN_USB_SCRIPT"
    assert_file_contains "$MODPROBE_DIR/harden-usb.conf" "install firewire-ohci /bin/false"
}

@test "harden-usb: blacklists firewire-sbp2 module" {
    bash "$HARDEN_USB_SCRIPT"
    assert_file_contains "$MODPROBE_DIR/harden-usb.conf" "blacklist firewire-sbp2"
}

@test "harden-usb: sets firewire-sbp2 install to /bin/false" {
    bash "$HARDEN_USB_SCRIPT"
    assert_file_contains "$MODPROBE_DIR/harden-usb.conf" "install firewire-sbp2 /bin/false"
