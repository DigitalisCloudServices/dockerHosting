#!/usr/bin/env bats
# Tests for scripts/harden-kernel.sh
# Validates kernel sysctl hardening configuration

load '../helpers/common'

setup() {
    setup_mocks
    
    # Override sysctl.d directory to test location
    export SYSCTL_DIR="$BATS_TEST_TMPDIR/etc/sysctl.d"
    mkdir -p "$SYSCTL_DIR"
    
    # Mock sysctl command to capture and validate calls
    SYSCTL_LOG="$BATS_TEST_TMPDIR/sysctl.log"
    create_mock_with_body "sysctl" "
        echo \"\$*\" >> \"$SYSCTL_LOG\"
        # Return sample values for verification queries
        case \"\$*\" in
            *randomize_va_space*) echo '2' ;;
            *tcp_syncookies*) echo '1' ;;
            *ip_forward*) echo '1' ;;
            *rp_filter*) echo '1' ;;
            *ptrace_scope*) echo '1' ;;
            *) exit 0 ;;
        esac
    "
    
    # Stub cat to write to our test location
    create_mock_with_body "cat" '
        if [[ "$1" == ">" && "$2" == /etc/sysctl.d/* ]]; then
            # Redirect to test location
            target="${2#/etc/sysctl.d/}"
            cat > "'"$SYSCTL_DIR"'/$target"
        else
            /bin/cat "$@"
        fi
    '
}

teardown() {
    teardown_mocks
}

# ── sysctl.d file generation ──────────────────────────────────────────────────

@test "harden-kernel: creates 99-security.conf in sysctl.d" {
    # Modify script to use our SYSCTL_DIR
    local test_script="$BATS_TEST_TMPDIR/harden-kernel-test.sh"
    sed "s|/etc/sysctl.d|$SYSCTL_DIR|g" "$SCRIPTS_DIR/harden-kernel.sh" > "$test_script"
    chmod +x "$test_script"
    
    run bash "$test_script"
    [ "$status" -eq 0 ]
    assert_file_exists "$SYSCTL_DIR/99-security.conf"
}

@test "harden-kernel: config file has correct header" {
    local test_script="$BATS_TEST_TMPDIR/harden-kernel-test.sh"
    sed "s|/etc/sysctl.d|$SYSCTL_DIR|g" "$SCRIPTS_DIR/harden-kernel.sh" > "$test_script"
    chmod +x "$test_script"
    
    bash "$test_script"
    assert_file_contains "$SYSCTL_DIR/99-security.conf" "# Kernel Hardening Configuration"
    assert_file_contains "$SYSCTL_DIR/99-security.conf" "# Generated by dockerHosting security hardening"
}

@test "harden-kernel: config file is valid conf syntax (no HEREDOC markers)" {
    local test_script="$BATS_TEST_TMPDIR/harden-kernel-test.sh"
    sed "s|/etc/sysctl.d|$SYSCTL_DIR|g" "$SCRIPTS_DIR/harden-kernel.sh" > "$test_script"
    chmod +x "$test_script"
    
    bash "$test_script"
    refute_file_contains "$SYSCTL_DIR/99-security.conf" "EOF"
    refute_file_contains "$SYSCTL_DIR/99-security.conf" "<<'"
}

