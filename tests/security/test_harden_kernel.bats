    # Check file is readable (at minimum: owner read)
    [ -r "$SYSCTL_DIR/99-security.conf" ]
}

@test "harden-kernel: generated config is a regular file (not directory/symlink)" {
    local test_script="$BATS_TEST_TMPDIR/harden-kernel-test.sh"
    sed "s|/etc/sysctl.d|$SYSCTL_DIR|g" "$SCRIPTS_DIR/harden-kernel.sh" > "$test_script"
    chmod +x "$test_script"
    
    bash "$test_script"
    
    [ -f "$SYSCTL_DIR/99-security.conf" ]
    [ ! -L "$SYSCTL_DIR/99-security.conf" ]
    [ ! -d "$SYSCTL_DIR/99-security.conf" ]
}

