@test "harden-usb: firewire section mentions DMA bypass risk" {
    bash "$HARDEN_USB_SCRIPT"
    assert_file_contains "$MODPROBE_DIR/harden-usb.conf" "DMA-capable"
    assert_file_contains "$MODPROBE_DIR/harden-usb.conf" "bypass OS memory protections"
